"## Section 2. 유틸리티 함수: 최근 실행 결과 불러오기\n",
"벤치마크 스크립트 실행 후 results/model_suite_<timestamp> 폴더에 생성되는 CSV를 자동으로 읽어오기 위한 헬퍼 함수입니다."
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"def get_latest_result_dir(version_root):\n",
"    results_dir = Path(version_root) / "results"\n",
"    subdirs = [d for d in results_dir.iterdir() if d.is_dir() and d.name.startswith("model_suite_")]\n",
"    if not subdirs:\n",
"        return None\n",
"    latest_dir = max(subdirs, key=os.path.getmtime)\n",
"    return latest_dir\n",
"\n",
"def inspect_latest_row_comparison(version_root):\n",
"    latest_dir = get_latest_result_dir(version_root)\n",
"    if not latest_dir:\n",
"        print("No results directory found.")\n",
"        return None\n",
"    \n",
"    csv_path = latest_dir / "row_comparison.csv"\n",
"    if not csv_path.exists():\n",
"        print(f"row_comparison.csv not found in {latest_dir}")\n",
"        return None\n",
"        \n",
"    print(f"Loading results from: {csv_path}")\n",
"    df = pd.read_csv(csv_path)\n",
"    \n",
"    # 핵심 확인 지표 필터링\n",
"    target_cols = [col for col in ['row_no', 'model_key', 'det_score', 'is_pass', 'failure_reasons', 'prompt_tokens', 'latency', 'generated_code'] if col in df.columns]\n",
"    return df[target_cols]\n"
]
},
